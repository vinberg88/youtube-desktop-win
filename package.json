{
  "name": "tubedesk-for-windows",
  "version": "0.4.2",
  "description": "A polished, unofficial desktop wrapper for YouTube and YouTube Music on Windows.",
  "main": "main.js",
  "author": "Mattias Vinberg",
  "companyName": "Mattias Vinberg",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "build:store": "electron-builder --win appx",
    "build:all": "electron-builder --win nsis appx",
    "dist": "npm run build"
  },
  "build": {
    "appId": "se.vinberg.tubedesk",
    "productName": "TubeDesk for Windows",
    "copyright": "Copyright © 2026 Mattias Vinberg",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "mini.html",
      "README.md",
      "PRIVACY.md",
      "STORE-LISTING.md",
      "LICENSE",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "legalTrademarks": "TubeDesk for Windows is an unofficial app. YouTube and YouTube Music are trademarks of Google LLC."
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TubeDesk for Windows",
      "artifactName": "TubeDesk-for-Windows-Setup-${version}.${ext}",
      "include": "build/installer.nsh"
    },
    "appx": {
      "applicationId": "TubeDeskForWindows",
      "backgroundColor": "#0f0f0f",
      "displayName": "TubeDesk for Windows",
      "publisherDisplayName": "Mattias Vinberg",
      "identityName": "Vinberg88.TubeDeskForWindows",
      "languages": [
        "sv-SE",
        "en-US"
      ]
    }
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
